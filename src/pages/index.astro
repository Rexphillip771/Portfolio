---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="max-w-4xl mx-auto px-5 py-16">
		<!-- Hero Section -->
		<section class="min-h-[80vh] flex items-center justify-center text-center py-10">
			<div class="space-y-6">
				<span class="inline-block px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-gray-300 text-sm border border-white/20">
					📍 Digos City, Davao Del Sur
				</span>
				<h1 class="text-4xl md:text-5xl font-bold bg-linear-to-r from-white to-blue-300 bg-clip-text text-transparent">
					Shawn Melchor P. Trondillo
				</h1>
				<p class="text-xl text-blue-300 font-medium">
					Virtual Marketing Assistant & IT Graduate | Startup Founder
				</p>
				<p class="text-gray-300 max-w-xl mx-auto text-lg">
					BS Information Technology graduate with a passion for building digital solutions.
					Currently working as a Virtual Marketing Assistant while co-founding
					Nourish360 — a digital health startup reimagining nutrition care.
				</p>
				<div class="flex gap-4 justify-center flex-wrap pt-4">
					<a href="#contact" class="px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-full transition-all hover:-translate-y-0.5 shadow-lg hover:shadow-blue-500/40">
						Get in Touch
					</a>
					<a href="#about" class="px-6 py-3 border-2 border-white/30 hover:bg-white/10 text-white font-semibold rounded-full transition-all hover:-translate-y-0.5">
						Learn More
					</a>
				</div>
			</div>
		</section>

		<!-- About Section -->
		<section id="about" class="bg-white/10 backdrop-blur-md rounded-2xl p-8 md:p-12 my-5 border border-white/20 shadow-xl">
			<h2 class="text-3xl font-bold text-center mb-8 relative">
				About Me
				<span class="block w-16 h-1 bg-blue-500 mx-auto mt-3 rounded-full"></span>
			</h2>
			<div class="space-y-5 text-gray-200">
				<p class="text-lg leading-relaxed">
					<span class="text-4xl text-blue-400 float-left mr-2 font-bold">H</span>
					i there! I'm Shawn, a fresh BS Information Technology graduate from the
					University of Immaculate Conception, Davao City (2025). I'm currently working
					as a Virtual Marketing Assistant, helping businesses grow digitally and connect
					with their audiences more effectively.
				</p>
				<p class="text-lg leading-relaxed">
					Beyond marketing, I'm a startup founder — Nourish360, a digital health solution
					digitalizing the Nutrition Care Process, started as my capstone project and is now
					an active startup under a TBI organization. I was also a champion at the
					Techstars Startup Weekend Social Innovation Davao 2023.
				</p>
				<p class="text-lg leading-relaxed">
					I'm proactive, resourceful, and always eager to combine technology with
					real-world impact. Based in Digos City, Davao Del Sur, and open to remote
					opportunities, collaborations, and exciting new projects.
				</p>
			</div>
		</section>

		<!-- Skills Section -->
		<section id="skills" class="py-10">
			<h2 class="text-3xl font-bold text-center mb-8 relative text-white">
				What I Do
				<span class="block w-16 h-1 bg-blue-500 mx-auto mt-3 rounded-full"></span>
			</h2>
			<div class="flex flex-wrap justify-center gap-3 mb-8">
				<button class="tab-btn active px-5 py-2.5 bg-blue-500 text-white font-medium rounded-full shadow-lg shadow-blue-500/40 transition-all hover:-translate-y-0.5" data-tab="marketing">
					Marketing
				</button>
				<button class="tab-btn px-5 py-2.5 bg-white/10 text-gray-200 font-medium rounded-full border border-white/20 hover:bg-white/20 transition-all hover:-translate-y-0.5" data-tab="development">
					Development
				</button>
				<button class="tab-btn px-5 py-2.5 bg-white/10 text-gray-200 font-medium rounded-full border border-white/20 hover:bg-white/20 transition-all hover:-translate-y-0.5" data-tab="tools">
					Tools
				</button>
				<button class="tab-btn px-5 py-2.5 bg-white/10 text-gray-200 font-medium rounded-full border border-white/20 hover:bg-white/20 transition-all hover:-translate-y-0.5" data-tab="soft">
					Soft Skills
				</button>
			</div>
			<div class="tab-panels min-h-70">
				<!-- Marketing -->
				<div class="tab-content active grid md:grid-cols-2 gap-4" id="marketing">
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">📊</div>
						<h4 class="text-white font-semibold text-lg mb-1">Digital Marketing Strategy</h4>
						<p class="text-gray-300">Creating data-driven campaigns that convert</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">📱</div>
						<h4 class="text-white font-semibold text-lg mb-1">Social Media Management</h4>
						<p class="text-gray-300">Building brand presence across platforms</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">✉️</div>
						<h4 class="text-white font-semibold text-lg mb-1">Email Marketing</h4>
						<p class="text-gray-300">Crafting engaging newsletters & campaigns</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">✍️</div>
						<h4 class="text-white font-semibold text-lg mb-1">Content Creation</h4>
						<p class="text-gray-300">Compelling content that tells your story</p>
					</div>
				</div>
				<!-- Development -->
				<div class="tab-content  md:grid-cols-2 gap-4 hidden" id="development">
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🐍</div>
						<h4 class="text-white font-semibold text-lg mb-1">Python</h4>
						<p class="text-gray-300">Automation, data processing & backend</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">⚛️</div>
						<h4 class="text-white font-semibold text-lg mb-1">React</h4>
						<p class="text-gray-300">Modern frontend development</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🌐</div>
						<h4 class="text-white font-semibold text-lg mb-1">HTML / CSS / Astro</h4>
						<p class="text-gray-300">Building responsive websites</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">☕</div>
						<h4 class="text-white font-semibold text-lg mb-1">Java</h4>
						<p class="text-gray-300">Object-oriented programming</p>
					</div>
				</div>
				<!-- Tools -->
				<div class="tab-content md:grid-cols-2 gap-4 hidden" id="tools">
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🐙</div>
						<h4 class="text-white font-semibold text-lg mb-1">Git & GitHub</h4>
						<p class="text-gray-300">Version control & collaboration</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🔥</div>
						<h4 class="text-white font-semibold text-lg mb-1">Firebase</h4>
						<p class="text-gray-300">Realtime databases & auth</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🎨</div>
						<h4 class="text-white font-semibold text-lg mb-1">Figma</h4>
						<p class="text-gray-300">UI/UX design & prototyping</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">☁️</div>
						<h4 class="text-white font-semibold text-lg mb-1">AWS</h4>
						<p class="text-gray-300">Cloud infrastructure</p>
					</div>
				</div>
				<!-- Soft Skills -->
				<div class="tab-content  md:grid-cols-2 gap-4 hidden" id="soft">
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🤝</div>
						<h4 class="text-white font-semibold text-lg mb-1">Teamwork & Collaboration</h4>
						<p class="text-gray-300">Working effectively in diverse teams</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🧩</div>
						<h4 class="text-white font-semibold text-lg mb-1">Problem-Solving</h4>
						<p class="text-gray-300">Analytical thinking & solutions</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🚀</div>
						<h4 class="text-white font-semibold text-lg mb-1">Proactive & Resourceful</h4>
						<p class="text-gray-300">Taking initiative & finding ways</p>
					</div>
					<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border border-white/20 hover:bg-white/15 transition-all hover:-translate-y-1">
						<div class="text-3xl mb-3">🗣️</div>
						<h4 class="text-white font-semibold text-lg mb-1">Business Communication</h4>
						<p class="text-gray-300">Clear, professional messaging</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Section -->
		<section id="projects" class="py-10">
			<h2 class="text-3xl font-bold text-center mb-8 relative text-white">
				Projects & Experience
				<span class="block w-16 h-1 bg-blue-500 mx-auto mt-3 rounded-full"></span>
			</h2>
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
				<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border-t-4 border-blue-500 border hover:bg-white/15 transition-all hover:-translate-y-1">
					<div class="flex justify-between items-start mb-2">
						<h3 class="text-white font-semibold text-lg">Nourish360</h3>
						<span class="text-xs bg-blue-500/20 text-blue-300 px-2 py-1 rounded-full">Startup · Jul 2024 – Present</span>
					</div>
					<p class="text-blue-300 text-sm mb-3 italic">Digitalizing the Nutrition Care Process</p>
					<p class="text-gray-300 text-sm leading-relaxed">
						Started as a capstone project, now a live startup under a TBI organization.
						I assembled and led a team to design and iterate on a digital health solution
						covering product development, business strategy, and customer service.
					</p>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border-t-4 border-blue-500 border  hover:bg-white/15 transition-all hover:-translate-y-1">
					<div class="flex justify-between items-start mb-2">
						<h3 class="text-white font-semibold text-lg">Tech Start-Up Event Champion</h3>
						<span class="text-xs bg-blue-500/20 text-blue-300 px-2 py-1 rounded-full">Techstars · 2023</span>
					</div>
					<p class="text-blue-300 text-sm mb-3 italic">Techstars Startup Weekend Social Innovation Davao</p>
					<p class="text-gray-300 text-sm leading-relaxed">
						Collaborated as a team to ideate and build a prototype helping cancer patients
						navigate their journey. Presented a working demo and business model to judges
						and won the championship title.
					</p>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-6 rounded-xl border-t-4 border-blue-500 border  hover:bg-white/15 transition-all hover:-translate-y-1">
					<div class="flex justify-between items-start mb-2">
						<h3 class="text-white font-semibold text-lg">Red Cross Action Team</h3>
						<span class="text-xs bg-blue-500/20 text-blue-300 px-2 py-1 rounded-full">Volunteer · 2014 – 2020</span>
					</div>
					<p class="text-blue-300 text-sm mb-3 italic">Member & PIO – Cor Jesu College</p>
					<p class="text-gray-300 text-sm leading-relaxed">
						Served as a registered RCAT member and PIO for the Red Cross Youth club.
						Participated in first aid stations, patrols, and disaster response during
						Mindanao earthquakes, supporting community outreach and relief distribution.
					</p>
				</div>
			</div>
		</section>

		<!-- Certifications Section -->
		<section id="certifications" class="py-10">
			<h2 class="text-3xl font-bold text-center mb-8 relative text-white">
				Certifications & Awards
				<span class="block w-16 h-1 bg-blue-500 mx-auto mt-3 rounded-full"></span>
			</h2>
			<div class="grid md:grid-cols-2 gap-4">
				<div class="bg-white/10 backdrop-blur-md p-5 rounded-xl border border-white/20 flex items-center gap-4 hover:bg-white/15 transition-all">
					<span class="text-3xl">🏆</span>
					<div>
						<h4 class="text-white font-semibold">Champion – Techstars Startup Weekend Social Innovation Davao</h4>
						<p class="text-gray-400 text-sm">Techstars, Davao City · September 2023</p>
					</div>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-5 rounded-xl border border-white/20 flex items-center gap-4 hover:bg-white/15 transition-all">
					<span class="text-3xl">⭐</span>
					<div>
						<h4 class="text-white font-semibold">Outstanding Performance Award</h4>
						<p class="text-gray-400 text-sm">University of Immaculate Conception · April 2025</p>
					</div>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-5 rounded-xl border border-white/20 flex items-center gap-4 hover:bg-white/15 transition-all">
					<span class="text-3xl">📜</span>
					<div>
						<h4 class="text-white font-semibold">Front-End Development Using React</h4>
						<p class="text-gray-400 text-sm">Coursera · 2025</p>
					</div>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-5 rounded-xl border border-white/20 flex items-center gap-4 hover:bg-white/15 transition-all">
					<span class="text-3xl">📜</span>
					<div>
						<h4 class="text-white font-semibold">JavaScript Web Development</h4>
						<p class="text-gray-400 text-sm">Coursera · 2025</p>
					</div>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-5 rounded-xl border border-white/20 flex items-center gap-4 hover:bg-white/15 transition-all">
					<span class="text-3xl">☁️</span>
					<div>
						<h4 class="text-white font-semibold">AWS Certified Solutions Architect</h4>
						<p class="text-gray-400 text-sm">Coursera · 2025</p>
					</div>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-5 rounded-xl border border-white/20 flex items-center gap-4 hover:bg-white/15 transition-all">
					<span class="text-3xl">🎤</span>
					<div>
						<h4 class="text-white font-semibold">English for Effective Business Speaking</h4>
						<p class="text-gray-400 text-sm">Coursera · 2025</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section id="contact" class="bg-white/10 backdrop-blur-md rounded-2xl p-8 md:p-12 my-5 border border-white/20 shadow-xl">
			<h2 class="text-3xl font-bold text-center mb-4 relative text-white">
				Let's Connect
				<span class="block w-16 h-1 bg-blue-500 mx-auto mt-3 rounded-full"></span>
			</h2>
			<p class="text-gray-300 text-center mb-8 text-lg">
				Got a project in mind, want to collaborate, or just want to say hi?
				I'd love to hear from you!
			</p>
			<div class="flex flex-wrap justify-center gap-4 mb-8">
				<a href="mailto:strondillo@gmail.com" class="flex items-center gap-2 px-5 py-3 bg-white/10 hover:bg-white/20 text-white rounded-lg border border-white/20 transition-all hover:-translate-y-0.5">
					<span class="text-xl">✉️</span>
					<span>strondillo@gmail.com</span>
				</a>
				<a href="mailto:strondillo@yahoo.com" class="flex items-center gap-2 px-5 py-3 bg-white/10 hover:bg-white/20 text-white rounded-lg border border-white/20 transition-all hover:-translate-y-0.5">
					<span class="text-xl">📧</span>
					<span>strondillo@yahoo.com</span>
				</a>
				<a href="https://www.linkedin.com/in/shawn-trondillo-b3a426345/" target="_blank" class="flex items-center gap-2 px-5 py-3 bg-white/10 hover:bg-white/20 text-white rounded-lg border border-white/20 transition-all hover:-translate-y-0.5">
					<span class="text-xl">💼</span>
					<span>LinkedIn</span>
				</a>
				<a href="https://github.com/Rexphillip771" target="_blank" class="flex items-center gap-2 px-5 py-3 bg-white/10 hover:bg-white/20 text-white rounded-lg border border-white/20 transition-all hover:-translate-y-0.5">
					<span class="text-xl">💻</span>
					<span>GitHub</span>
				</a>
			</div>
			<form class="max-w-md mx-auto space-y-4" action="mailto:strondillo@gmail.com" method="post" enctype="text/plain">
				<div>
					<label for="name" class="block text-white font-medium mb-2">Name</label>
					<input type="text" id="name" name="name" placeholder="Your name" required 
						class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:bg-white/15 backdrop-blur-sm" />
				</div>
				<div>
					<label for="email" class="block text-white font-medium mb-2">Email</label>
					<input type="email" id="email" name="email" placeholder="your@email.com" required 
						class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:bg-white/15 backdrop-blur-sm" />
				</div>
				<div>
					<label for="message" class="block text-white font-medium mb-2">Message</label>
					<textarea id="message" name="message" rows="4" placeholder="What's on your mind?" required 
						class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:bg-white/15 backdrop-blur-sm resize-none"></textarea>
				</div>
				<button type="submit" class="w-full px-6 py-3 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-lg transition-all hover:-translate-y-0.5 shadow-lg shadow-blue-500/40">
					Send Message
				</button>
			</form>
		</section>

		<!-- Footer -->
		<footer class="text-center py-8 text-gray-400">
			<p>© 2026 Shawn Melchor P. Trondillo. Built with passion ☕</p>
		</footer>
	</main>

	<script>
		const tabs = document.querySelectorAll('.tab-btn');
		const contents = document.querySelectorAll('.tab-content');

		tabs.forEach(tab => {
			tab.addEventListener('click', () => {
				tabs.forEach(t => {
					t.classList.remove('active', 'bg-blue-500', 'shadow-lg', 'shadow-blue-500/40');
					t.classList.add('bg-white/10', 'border', 'border-white/20');
				});
				contents.forEach(c => {
					c.classList.add('hidden');
					c.classList.remove('active');
				});

				tab.classList.add('active', 'bg-blue-500', 'shadow-lg', 'shadow-blue-500/40');
				tab.classList.remove('bg-white/10', 'border', 'border-white/20');
				
				const targetId = tab.getAttribute('data-tab');
				const targetContent = document.getElementById(targetId!);
				if (targetContent) {
					targetContent.classList.remove('hidden');
					targetContent.classList.add('active');
				}
			});
		});
	</script>
</Layout>
