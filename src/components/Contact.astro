---
interface ContactData {
  emails: string[];
  github: string;
  linkedin: string;
}

interface Props {
  contact: ContactData;
}

const { contact } = Astro.props;
---

<section id="contact" class="py-16 md:py-24">
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-white">
    Let's Connect
    <span class="block w-16 h-1 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto mt-3 rounded-full"></span>
  </h2>

  <p class="text-gray-400 text-center mb-8 text-lg max-w-xl mx-auto">
    Got a project in mind, want to collaborate, or just want to say hi? I'd love to hear from you!
  </p>

  <div class="flex flex-wrap justify-center gap-4 mb-10">
    {contact.emails.map((email: string) => (
      <a
        href={`mailto:${email}`}
        class="flex items-center gap-2 px-5 py-3 bg-white/4 hover:bg-white/8 text-gray-200 rounded-lg border border-white/8 transition-all duration-300 hover:-translate-y-0.5"
      >
        <span class="text-xl">✉️</span>
        <span>{email}</span>
      </a>
    ))}
    <a
      href={contact.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 px-5 py-3 bg-white/4 hover:bg-white/8 text-gray-200 rounded-lg border border-white/8 transition-all duration-300 hover:-translate-y-0.5"
    >
      <span class="text-xl">💼</span>
      <span>LinkedIn</span>
    </a>
    <a
      href={contact.github}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 px-5 py-3 bg-white/4 hover:bg-white/8 text-gray-200 rounded-lg border border-white/8 transition-all duration-300 hover:-translate-y-0.5"
    >
      <span class="text-xl">💻</span>
      <span>GitHub</span>
    </a>
  </div>

  <form class="max-w-lg mx-auto space-y-5" action={`mailto:${contact.emails[0]}`} method="post" enctype="text/plain">
    <div>
      <label for="name" class="block text-gray-300 font-medium mb-2">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Your name"
        required
        class="w-full px-4 py-3 bg-white/4 border border-white/8 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 focus:bg-white/6 backdrop-blur-sm transition-all duration-300"
      />
    </div>
    <div>
      <label for="email" class="block text-gray-300 font-medium mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="your@email.com"
        required
        class="w-full px-4 py-3 bg-white/4 border border-white/8 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 focus:bg-white/6 backdrop-blur-sm transition-all duration-300"
      />
    </div>
    <div>
      <label for="message" class="block text-gray-300 font-medium mb-2">Message</label>
      <textarea
        id="message"
        name="message"
        rows="5"
        placeholder="Your message..."
        required
        class="w-full px-4 py-3 bg-white/4 border border-white/8 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 focus:bg-white/6 backdrop-blur-sm transition-all duration-300 resize-none"
      ></textarea>
    </div>
    <button
      type="submit"
      class="w-full px-6 py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-lg transition-all duration-300 hover:-translate-y-0.5 shadow-lg shadow-violet-600/25 hover:shadow-violet-500/40"
    >
      Send Message
    </button>
  </form>
</section>

<footer class="text-center py-8 border-t border-white/6 text-gray-500 text-sm">
  <p>© {new Date().getFullYear()} Shawn Melchor P. Trondillo. Built with passion ☕</p>
</footer>
