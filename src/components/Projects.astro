---
interface Experience {
  title: string;
  role: string;
  subtitle: string;
  description: string;
}

interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<section id="experience" class="py-16 md:py-24">
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-10 text-white">
    Projects & Experience
    <span class="block w-16 h-1 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto mt-3 rounded-full"></span>
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {experiences.map((exp: Experience) => (
      <div class="group bg-white/3 backdrop-blur-sm p-6 rounded-xl border border-white/6 border-t-4 border-t-violet-500/60 hover:bg-white/6 transition-all duration-300 hover:-translate-y-1">
        <div class="flex justify-between items-start mb-2 flex-wrap gap-2">
          <h3 class="text-white font-semibold text-lg">{exp.title}</h3>
          <span class="text-xs bg-violet-500/15 text-violet-300 px-2 py-1 rounded-full whitespace-nowrap">
            {exp.role}
          </span>
        </div>
        <p class="text-violet-300/70 text-sm mb-3 italic">{exp.subtitle}</p>
        <p class="text-gray-400 text-sm leading-relaxed">{exp.description}</p>
      </div>
    ))}
  </div>
</section>
