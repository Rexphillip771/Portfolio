---
interface Props {
  paragraphs: string[];
}

const { paragraphs } = Astro.props;
---

<section id="about" class="py-16 md:py-24">
  <div class="bg-white/3 backdrop-blur-xl rounded-2xl p-8 md:p-12 border border-white/6 shadow-xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-8">
      About Me
      <span class="block w-16 h-1 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto mt-3 rounded-full"></span>
    </h2>

    <div class="space-y-5 text-gray-300 max-w-3xl mx-auto">
      {
        paragraphs.map((p: string, i: number) => (
          <p class="text-lg leading-relaxed">
            {i === 0 && <span class="text-4xl text-violet-400 float-left mr-2 font-bold">H</span>}
            {i === 0 ? p.slice(1) : p}
          </p>
        ))
      }
    </div>
  </div>
</section>
