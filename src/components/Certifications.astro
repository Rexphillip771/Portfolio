---
interface Certification {
  icon: string;
  title: string;
  issuer: string;
}

interface Props {
  certifications: Certification[];
}

const { certifications } = Astro.props;
---

<section id="certifications" class="py-16 md:py-24">
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-10 text-white">
    Certifications & Awards
    <span class="block w-16 h-1 bg-linear-to-r from-violet-500 to-fuchsia-500 mx-auto mt-3 rounded-full"></span>
  </h2>

  <div class="grid md:grid-cols-2 gap-4">
    {certifications.map((cert: Certification) => (
      <div class="group flex items-center gap-4 bg-white/3 backdrop-blur-sm p-5 rounded-xl border border-white/6 hover:bg-white/6 transition-all duration-300 hover:-translate-y-0.5">
        <span class="text-3xl shrink-0">{cert.icon}</span>
        <div>
          <h4 class="text-white font-semibold">{cert.title}</h4>
          <p class="text-gray-400 text-sm">{cert.issuer}</p>
        </div>
      </div>
    ))}
  </div>
</section>
