---
interface Props {
  data: {
    name: string;
    title: string;
    tagline: string;
    location: string;
  };
}

const { data } = Astro.props;
---

<section class="min-h-screen flex items-center justify-center text-center py-10 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-violet-500/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-fuchsia-500/8 rounded-full blur-3xl animate-float" style="animation-delay: 2s"></div>
  </div>

  <div class="space-y-6 relative z-10 max-w-3xl mx-auto px-4">
    <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/4 backdrop-blur-sm rounded-full text-gray-400 text-sm border border-white/8 animate-fade-in">
      <span class="w-1.5 h-1.5 rounded-full bg-violet-400"></span>
      {data.location}
    </span>

    <h1 class="text-4xl md:text-6xl font-bold leading-tight animate-fade-in-up text-white drop-shadow-[0_0_30px_rgba(167,139,250,0.3)]">
      {data.name}
    </h1>

    <p class="text-xl text-violet-300/80 font-medium animate-fade-in-up" style="animation-delay: 0.15s">
      {data.title}
    </p>

    <p class="text-gray-400 max-w-2xl mx-auto text-lg leading-relaxed animate-fade-in-up" style="animation-delay: 0.3s">
      {data.tagline}
    </p>

    <div class="flex gap-4 justify-center flex-wrap pt-4 animate-fade-in-up" style="animation-delay: 0.45s">
      <a
        href="#contact"
        class="px-6 py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-full transition-all duration-300 hover:-translate-y-0.5 shadow-lg shadow-violet-600/25 hover:shadow-violet-500/40"
      >
        Get in Touch
      </a>
      <a
        href="#about"
        class="px-6 py-3 border border-white/20 hover:bg-white/6 text-gray-200 font-semibold rounded-full transition-all duration-300 hover:-translate-y-0.5"
      >
        Learn More
      </a>
    </div>
  </div>
</section>
